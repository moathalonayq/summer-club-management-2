# =========================================================
# .env.test.example
# انسخ هذا الملف وسمّه .env.test وضع فيه بيانات اتصال محلية بقاعدة
# بيانات MySQL مخصصة للاختبار فقط (منفصلة تماماً عن قاعدة بيانات التطوير/الإنتاج)
#
# تحذير أمني مهم: globalSetup.js يرفض العمل إذا لم يحتو اسم قاعدة
# البيانات على الكلمة "_test"، كحماية من تشغيل الاختبارات (التي تحذف
# الجداول) بالخطأ على بيانات حقيقية. التزم بهذه التسمية.
# =========================================================

DATABASE_URL=mysql://root:كلمة_السر@localhost:3306/qayrawan_club_test
PORT=3001
SESSION_SECRET=test-only-secret-do-not-use-in-production
SUPERVISOR_ACCESS_CODE=991
NODE_ENV=test
