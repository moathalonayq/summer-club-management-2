{
  "name": "qayrawan-club",
  "version": "1.0.0",
  "description": "موقع نادي القيروان - منصة متابعة الطلاب والبرامج",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "seed": "node config/seed.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --runInBand --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "test:db:setup": "cross-env NODE_ENV=test node tests/helpers/setupTestDb.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "mysql2": "^3.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./tests/helpers/globalSetup.js",
    "globalTeardown": "./tests/helpers/globalTeardown.js",
    "setupFilesAfterEnv": [
      "./tests/helpers/setupAfterEnv.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 15000,
    "verbose": true,
    "collectCoverageFrom": [
      "models/**/*.js",
      "controllers/**/*.js",
      "middleware/**/*.js",
      "routes/**/*.js",
      "app.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
