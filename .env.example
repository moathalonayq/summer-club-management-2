# =========================================================
# .env.example
# انسخ هذا الملف وسمّه .env وضع فيه القيم الحقيقية
# لا ترفع ملف .env الحقيقي إلى GitHub أبداً
# =========================================================

# الخيار الأول (يُفضَّل على Railway): رابط اتصال كامل بقاعدة بيانات MySQL
# على Railway: يوفّرها لك تلقائياً بعد إنشاء قاعدة بيانات MySQL في نفس المشروع
# محلياً مثال: mysql://root:1234@localhost:3306/qayrawan_club
DATABASE_URL=mysql://root:password@localhost:3306/qayrawan_club

# الخيار الثاني (بديل، يُستخدم تلقائياً فقط إذا لم تضع DATABASE_URL أعلاه):
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=qayrawan_club

# منفذ التشغيل (Railway يضبطه تلقائياً، محلياً اتركه 3000)
PORT=3000

# مفتاح تشفير الجلسات - غيّره لقيمة عشوائية طويلة قبل النشر
SESSION_SECRET=change-this-to-a-long-random-string

# رمز دخول المشرفين
SUPERVISOR_ACCESS_CODE=991

# development أو production
NODE_ENV=development
