<%- include('partials/header') %>

  <section class="app-section active">

    <!-- =========================================================
         نبذة تعريفية عن النادي
         ========================================================= -->
    <div class="intro-card">
      <h2 class="section-title">عن نادي القيروان</h2>
      <p class="section-desc intro-text">
        نادي القيروان الموسمي هو بيئة تعليمية وتربوية متكاملة، صُممت لتمنح الطلاب تجربة صيفية استثنائية تجمع بين التعلم، والمرح، والمنافسة، واكتساب المهارات. نؤمن بأن كل طالب يمتلك موهبة تستحق أن تُكتشف، وكل إنجاز يستحق أن يُحتفى به، ولذلك نوفر برامج متنوعة، وتحديات ممتعة، وأنشطة نوعية تصنع أثرًا يبقى.
      </p>

      <div class="club-quick-facts">
        <div class="quick-fact">
          <span class="quick-fact-value"><%= settings.total_weeks %></span>
          <span class="quick-fact-label">أسابيع النادي</span>
        </div>
        <div class="quick-fact">
          <span class="quick-fact-value"><%= settings.days_per_week %></span>
          <span class="quick-fact-label">أيام النادي أسبوعياً</span>
        </div>
        <div class="quick-fact">
          <span class="quick-fact-value"><%= settings.season_name %></span>
          <span class="quick-fact-label"></span>
        </div>
      </div>

      <div class="club-days-row">
        <% clubDays.forEach((day) => { %>
          <span class="club-day-chip"><%= day %></span>
        <% }) %>
        <span class="club-days-note">يبدأ النادي من 28 محرم لمدة 3 أسابيع</span>
      </div>
    </div>

    <h2 class="section-title">نظرة عامة على النادي</h2>
    <p class="section-desc">إحصائية شاملة عن نادي القيروان وأداء الطلاب في جميع البرامج</p>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= stats.totalStudents %></div>
        <div class="stat-label">عدد الطلاب</div>
      </div>
      <div class="stat-card gold">
        <div class="stat-value"><%= stats.totalGroups %></div>
        <div class="stat-label">عدد المجموعات</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.attendanceRate %></div>
        <div class="stat-label">عدد الحضور</div>
      </div>
      <div class="stat-card knowledge">
        <div class="stat-value"><%= stats.totalKnowledge %></div>
        <div class="stat-label">نقاط البرنامج المعرفي</div>
      </div>
      <div class="stat-card sports">
        <div class="stat-value"><%= stats.totalSports %></div>
        <div class="stat-label">نقاط البرنامج الرياضي</div>
      </div>
      <div class="stat-card cultural">
        <div class="stat-value"><%= stats.totalCultural %></div>
        <div class="stat-label">نقاط البرنامج الترفيهي</div>
      </div>
      <div class="stat-card gold">
        <div class="stat-value"><%= stats.totalInitiatives %></div>
        <div class="stat-label">نقاط المبادرات المميزة</div>
      </div>
    </div>

    <h3 class="section-title" style="font-size:19px; margin-top:10px;">البرامج الأربعة في النادي</h3>
    <p class="section-desc">كل طالب يتابَع أداؤه عبر أربع محاور رئيسية طوال الموسم</p>

    <div class="programs-grid">
      <div class="program-card knowledge">
        <h3>🟦 البرنامج المعرفي</h3>
        <p>يشمل مجموعة من البرامج والموضوعات الهادفة التي تنمّي الفكر والمهارات، مثل الذكاء الاصطناعي، والآداب، وبرنامج "صلاتي سعادتي"، إلى جانب أنشطة تعليمية وتفاعلية تعزز المعرفة والقيم لدى الطالب.</p>
      </div>
      <div class="program-card sports">
        <h3>⚽️ البرنامج الرياضي</h3>
        <p>يهدف إلى تعزيز اللياقة البدنية وروح المنافسة، من خلال الألعاب والبطولات والأنشطة الرياضية المتنوعة، في بيئة آمنة تشجع على التعاون والانضباط والمرح.</p>
      </div>
      <div class="program-card cultural">
        <h3>🎭 البرنامج الترفيهي</h3>
        <p>يوفر تجربة مليئة بالمتعة والتفاعل عبر الألعاب الجماعية، والمسابقات، والأنشطة الإبداعية، والفعاليات التي تنمي الثقة بالنفس وتقوي روح الفريق.</p>
      </div>
      <div class="program-card initiatives">
        <h3>🌟 التميز والمبادرات</h3>
        <p>يُكرّم الطلاب المتميزين وأصحاب المبادرات الإيجابية، ويشجع على الإبداع، والتعاون، وتحمل المسؤولية، من خلال منح إنجازات وأوسمة تعكس أثر الطالب داخل النادي وخارجه.</p>
      </div>
    </div>

    <!-- =========================================================
         المتصدرون: أفضل 5 من كل فئة
         ========================================================= -->
    <h3 class="section-title" style="font-size:19px; margin-top:36px;">🏆 المتصدرون</h3>
    <p class="section-desc">أفضل 10 طلاب من كل فئة حسب إجمالي النقاط</p>

    <div class="top-students-split">
      <div class="top-students-col">
        <h4 class="top-cat-title major-title">🥇 الفئة العليا</h4>
        <div class="data-table-wrapper">
          <table class="data-table">
            <thead>
              <tr><th>#</th><th>الاسم</th><th>المجموعة</th><th>الإجمالي</th></tr>
            </thead>
            <tbody>
              <% (topByCategory['الفئة العليا'] || []).forEach((s, i) => { %>
                <tr class="<%= i === 0 ? 'rank-gold-row' : i === 1 ? 'rank-silver-row' : i === 2 ? 'rank-bronze-row' : '' %>">
                  <td><%= i + 1 %></td>
                  <td><%= s.name %></td>
                  <td><%= s.group_name %></td>
                  <td><strong><%= s.total_points %></strong></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="top-students-col">
        <h4 class="top-cat-title minor-title">🌟 الفئة الأولية</h4>
        <div class="data-table-wrapper">
          <table class="data-table">
            <thead>
              <tr><th>#</th><th>الاسم</th><th>المجموعة</th><th>الإجمالي</th></tr>
            </thead>
            <tbody>
              <% (topByCategory['الأولوية'] || []).forEach((s, i) => { %>
                <tr class="<%= i === 0 ? 'rank-gold-row' : i === 1 ? 'rank-silver-row' : i === 2 ? 'rank-bronze-row' : '' %>">
                  <td><%= i + 1 %></td>
                  <td><%= s.name %></td>
                  <td><%= s.group_name %></td>
                  <td><strong><%= s.total_points %></strong></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </section>

<%- include('partials/footer') %>
