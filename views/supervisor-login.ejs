<%- include('partials/header') %>

  <section class="app-section active">
    <h2 class="section-title">لوحة المشرفين</h2>
    <p class="section-desc">أدخل رمز الدخول الخاص بالمشرفين للوصول إلى لوحة التحكم</p>

    <div class="supervisor-login">
      <h3>تسجيل دخول المشرف</h3>
      <p>أدخل رمز الدخول للوصول إلى لوحة التحكم</p>

      <form method="POST" action="/supervisor/login">
        <div class="form-group">
          <label for="accessCode">رمز الدخول</label>
          <input type="password" name="accessCode" id="accessCode" class="form-input" placeholder="••••••••" autofocus required>
        </div>
        <button type="submit" class="btn btn-primary">دخول</button>
        <% if (error) { %>
          <p class="error-text"><%= error %></p>
        <% } %>
      </form>
    </div>
  </section>

<%- include('partials/footer') %>
