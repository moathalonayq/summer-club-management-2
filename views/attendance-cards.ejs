<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>بطاقات التحضير - نادي القيروان</title>
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
  <style>
    * {
      box-sizing: border-box;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      color-adjust: exact;
    }
    body {
      margin: 0;
      font-family: "Tajawal", "Segoe UI", Tahoma, sans-serif;
      background: #ececec;
    }

    .toolbar {
      position: sticky;
      top: 0;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 20px;
      background: #1e2a4a;
      color: #fff;
    }
    .toolbar button {
      background: #ffd530;
      color: #1e2a4a;
      border: none;
      border-radius: 8px;
      padding: 10px 20px;
      font-weight: 800;
      font-size: 14px;
      cursor: pointer;
    }

    .cards-grid {
      padding: 24px;
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
      justify-content: center;
    }

    .card {
      width: 300px;
      height: 510px;
      border-radius: 20px;
      position: relative;
      overflow: hidden;
      color: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 26px 20px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.18);
    }
    .card.red    { background: #d9614e; }
    .card.blue   { background: #3b9c90; }
    .card.purple { background: #8083c9; }

    .card-logo { width: 130px; margin-bottom: 4px; filter: brightness(0) invert(1); }
    .card-club-name { font-size: 13px; font-weight: 700; margin-top: 2px; }
    .card-season { font-size: 11px; opacity: 0.9; margin-top: 1px; }

    .card-title {
      font-size: 26px;
      font-weight: 900;
      margin: 22px 0 18px;
    }

    .qr-box {
      background: #fff;
      border-radius: 14px;
      padding: 14px;
      width: 178px;
      height: 178px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .qr-box img { width: 100%; height: 100%; }

    .name-box {
      margin-top: auto;
      background: #fff;
      color: #222;
      width: 100%;
      border-radius: 14px;
      padding: 14px 10px;
      text-align: center;
      font-size: 16px;
      font-weight: 800;
    }
    .group-label {
      font-size: 11px;
      font-weight: 600;
      opacity: 0.9;
      margin-top: 4px;
    }

    /* حجم الصفحة عند الطباعة يطابق نسبة البطاقة (300×510) تماماً حتى لا تتمدد أو تنكمش */
    @page {
      size: 3.125in 5.3125in;
      margin: 0;
    }
    @media print {
      .toolbar { display: none; }
      body { background: #fff; }
      .cards-grid { padding: 0; gap: 0; }
      .card {
        box-shadow: none;
        border-radius: 0;
        page-break-after: always;
        width: 3.125in;
        height: 5.3125in;
        justify-content: center;
      }
    }
  </style>
</head>
<body>

  <div class="toolbar">
    <span>بطاقات التحضير — <%= cards.length %> طالباً<br><small>عند فتح نافذة الطباعة، تأكد من تفعيل خيار "طباعة الخلفيات/الألوان" (Background graphics) حتى تظهر الألوان</small></span>
    <button onclick="window.print()">🖨️ طباعة / حفظ PDF</button>
  </div>

  <div class="cards-grid" id="cardsGrid">
    <% cards.forEach((c, i) => { %>
      <div class="card <%= c.color %>">
        <img src="/img/logo.png" class="card-logo" alt="نادي القيروان">
        <h1 class="card-title">بطاقة التحضير</h1>
        <div class="qr-box" id="qr-<%= i %>"></div>
        <div class="name-box">
          <%= c.name %>
          <div class="group-label"><%= c.groupName %></div>
        </div>
      </div>
    <% }) %>
  </div>

  <script>
    const cards = <%- JSON.stringify(cards) %>;
    cards.forEach((c, i) => {
      new QRCode(document.getElementById("qr-" + i), {
        text: c.barcode,
        width: 150,
        height: 150,
        colorDark: "#0f3d33",
        colorLight: "#ffffff",
      });
    });
  </script>
</body>
</html>
