<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>نادي القيروان | <%= pageTitle %></title>
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <link rel="stylesheet" href="/css/style.css">

  <!-- مكتبة توليد رموز QR -->
  <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
  <!-- مكتبة قراءة رموز QR عبر الكاميرا -->
  <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>
</head>
<body>

  <div class="pattern-strip"></div>

  <header class="top-header">
    <img src="/img/logo.png" alt="نادي القيروان الموسمي" class="club-logo-img">

    <nav class="main-nav">
      <a href="/" class="nav-btn <%= activeNav === 'home' ? 'active' : '' %>">الرئيسية</a>
      <a href="/guardian" class="nav-btn <%= activeNav === 'guardian' ? 'active' : '' %>">ولي الأمر</a>
      <a href="/groups" class="nav-btn <%= activeNav === 'groups' ? 'active' : '' %>">المجموعات</a>
      <% if (isSupervisor) { %>
        <a href="/supervisor/panel" class="nav-btn <%= activeNav === 'supervisor' ? 'active' : '' %>">المشرفين</a>
      <% } else { %>
        <a href="/supervisor/login" class="nav-btn <%= activeNav === 'supervisor' ? 'active' : '' %>">المشرفين</a>
      <% } %>
    </nav>
  </header>

  <main class="app-main">
