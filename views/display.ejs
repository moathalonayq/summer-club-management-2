<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>نادي القيروان — شاشة الاستقبال</title>
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:   #1a2e4a;
      --gold:   #f5c518;
      --white:  #ffffff;
      --cream:  #fdf8f0;
      --slide-duration: 7s;
    }

    html, body {
      height: 100%; width: 100%;
      background: var(--navy);
      font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
      overflow: hidden;
      color: var(--white);
      user-select: none;
    }

    /* ======= شريط التقدم العلوي ======= */
    #progressBar {
      position: fixed; top: 0; left: 0; right: 0;
      height: 5px; z-index: 100;
      background: rgba(255,255,255,0.15);
    }
    #progressFill {
      height: 100%; width: 0%;
      background: var(--gold);
      transition: width linear;
    }

    /* ======= شريط علوي ثابت ======= */
    .top-bar {
      position: fixed; top: 5px; left: 0; right: 0;
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 32px; z-index: 90;
      background: rgba(26,46,74,0.85);
      backdrop-filter: blur(6px);
      border-bottom: 2px solid rgba(245,197,24,0.3);
    }
    .top-bar-logo { height: 52px; }
    .top-bar-title { font-size: 1.25rem; font-weight: 700; color: var(--gold); }
    .top-bar-time  { font-size: 1.1rem; color: rgba(255,255,255,0.75); font-variant-numeric: tabular-nums; }

    /* ======= مؤشر الشرائح ======= */
    .slide-dots {
      position: fixed; bottom: 18px; left: 50%; transform: translateX(-50%);
      display: flex; gap: 10px; z-index: 100;
    }
    .dot {
      width: 10px; height: 10px; border-radius: 50%;
      background: rgba(255,255,255,0.3);
      transition: background 0.3s, transform 0.3s;
    }
    .dot.active { background: var(--gold); transform: scale(1.4); }

    /* ======= الشرائح ======= */
    .slides-wrapper { position: relative; width: 100vw; height: 100vh; }

    .slide {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 100px 48px 60px;
      opacity: 0; transform: translateX(60px);
      transition: opacity 0.7s ease, transform 0.7s ease;
      pointer-events: none;
    }
    .slide.active {
      opacity: 1; transform: translateX(0);
      pointer-events: auto;
    }

    /* ===== شريحة 1: الترحيب ===== */
    .slide-welcome { background: linear-gradient(135deg, #0d1f35 0%, #1a3a5c 60%, #0d2a4a 100%); }
    .welcome-logo  { height: 130px; margin-bottom: 28px; filter: drop-shadow(0 4px 24px rgba(245,197,24,0.4)); }
    .welcome-title { font-size: 3.2rem; font-weight: 900; color: var(--gold); text-align: center; line-height: 1.2; }
    .welcome-sub   { font-size: 1.6rem; color: rgba(255,255,255,0.8); margin-top: 12px; text-align: center; }
    .welcome-chips { display: flex; gap: 16px; margin-top: 36px; flex-wrap: wrap; justify-content: center; }
    .welcome-chip  {
      padding: 10px 24px; border-radius: 50px;
      background: rgba(245,197,24,0.15);
      border: 2px solid rgba(245,197,24,0.4);
      font-size: 1.2rem; color: var(--gold); font-weight: 600;
    }
    .welcome-programs {
      display: flex; gap: 20px; margin-top: 40px; flex-wrap: wrap; justify-content: center;
    }
    .prog-badge {
      display: flex; flex-direction: column; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.07); border-radius: 16px;
      padding: 18px 28px; min-width: 130px;
      border: 1px solid rgba(255,255,255,0.12);
    }
    .prog-badge-icon { font-size: 2.2rem; }
    .prog-badge-label { font-size: 1rem; color: rgba(255,255,255,0.85); font-weight: 600; }

    /* ===== شريحة 2: المتصدرون ===== */
    .slide-leaders { background: linear-gradient(160deg, #0f2236 0%, #1a3455 100%); }
    .slide-title {
      font-size: 2rem; font-weight: 900; color: var(--gold);
      margin-bottom: 28px; display: flex; align-items: center; gap: 12px;
    }
    .leaders-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; width: 100%; max-width: 1100px; }
    .leaders-col-title {
      font-size: 1.2rem; font-weight: 700; color: var(--gold);
      margin-bottom: 12px; text-align: center; padding: 8px 0;
      border-bottom: 2px solid rgba(245,197,24,0.3);
    }
    .leader-row {
      display: flex; align-items: center; gap: 14px;
      padding: 10px 16px; border-radius: 12px;
      background: rgba(255,255,255,0.06);
      margin-bottom: 8px;
      transition: background 0.2s;
    }
    .leader-row.r1 { background: rgba(255,213,48,0.18); }
    .leader-row.r2 { background: rgba(180,180,180,0.14); }
    .leader-row.r3 { background: rgba(200,130,50,0.14); }
    .leader-rank  { font-size: 1.5rem; font-weight: 900; color: var(--gold); width: 32px; text-align: center; }
    .leader-name  { flex: 1; font-size: 1.05rem; font-weight: 600; }
    .leader-group { font-size: 0.85rem; color: rgba(255,255,255,0.55); }
    .leader-pts   { font-size: 1.2rem; font-weight: 900; color: var(--gold); }

    /* ===== شريحة 3: ترتيب المجموعات ===== */
    .slide-groups  { background: linear-gradient(150deg, #102030 0%, #1c3a58 100%); }
    .groups-display-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
      width: 100%; max-width: 1100px;
    }
    .group-display-card {
      display: flex; align-items: center; gap: 16px;
      padding: 14px 20px; border-radius: 14px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
    }
    .group-display-card.g1 { border-color: rgba(255,213,48,0.5); background: rgba(255,213,48,0.12); }
    .group-display-card.g2 { border-color: rgba(200,200,200,0.4); background: rgba(200,200,200,0.08); }
    .group-display-card.g3 { border-color: rgba(200,130,50,0.4);  background: rgba(200,130,50,0.08); }
    .gd-rank   { font-size: 2rem; font-weight: 900; color: var(--gold); width: 40px; text-align: center; }
    .gd-info   { flex: 1; }
    .gd-name   { font-size: 1.1rem; font-weight: 700; }
    .gd-cat    { font-size: 0.8rem; color: rgba(255,255,255,0.5); margin-top: 2px; }
    .gd-pts    { font-size: 1.4rem; font-weight: 900; color: var(--gold); }
    .gd-medal  { font-size: 1.8rem; }

    /* ===== شريحة 4: إحصائيات اليوم ===== */
    .slide-stats { background: linear-gradient(140deg, #0c1e33 0%, #1b3654 100%); }
    .stats-display-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
      width: 100%; max-width: 900px; margin-bottom: 32px;
    }
    .stat-display-card {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 28px 20px; border-radius: 18px; gap: 10px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
    }
    .sdc-icon  { font-size: 2.4rem; }
    .sdc-value { font-size: 2.8rem; font-weight: 900; color: var(--gold); line-height: 1; }
    .sdc-label { font-size: 0.95rem; color: rgba(255,255,255,0.65); text-align: center; }
    .session-banner {
      background: rgba(245,197,24,0.12);
      border: 2px solid rgba(245,197,24,0.35);
      border-radius: 16px; padding: 16px 40px;
      font-size: 1.3rem; font-weight: 700; color: var(--gold); text-align: center;
    }

    /* ===== شريحة 5: البرامج ===== */
    .slide-programs { background: linear-gradient(145deg, #0e1f33 0%, #1d3a58 100%); }
    .programs-display-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;
      width: 100%; max-width: 1050px;
    }
    .prog-display-card {
      border-radius: 18px; padding: 28px 28px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
      display: flex; flex-direction: column; gap: 10px;
    }
    .pdc-icon  { font-size: 2.4rem; }
    .pdc-title { font-size: 1.3rem; font-weight: 800; color: var(--gold); }
    .pdc-desc  { font-size: 0.95rem; color: rgba(255,255,255,0.72); line-height: 1.6; }

    /* زر fullscreen */
    #fsBtn {
      position: fixed; bottom: 18px; right: 24px; z-index: 200;
      background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
      color: white; padding: 8px 14px; border-radius: 8px;
      cursor: pointer; font-size: 1.1rem;
    }
    #fsBtn:hover { background: rgba(255,255,255,0.2); }
  </style>
</head>
<body>

<!-- شريط التقدم -->
<div id="progressBar"><div id="progressFill"></div></div>

<!-- الشريط العلوي -->
<div class="top-bar">
  <img src="/img/logo.png" class="top-bar-logo" alt="نادي القيروان">
  <div class="top-bar-title">نادي القيروان الموسمي — <%= settings.season_name %></div>
  <div class="top-bar-time" id="liveClock"></div>
</div>

<!-- مؤشر الشرائح -->
<div class="slide-dots" id="slideDots"></div>

<!-- زر fullscreen -->
<button id="fsBtn" title="ملء الشاشة">⛶</button>

<!-- الشرائح -->
<div class="slides-wrapper">

  <!-- ===== شريحة 1: الترحيب ===== -->
  <div class="slide slide-welcome active" id="slide-0">
    <img src="/img/logo.png" class="welcome-logo" alt="شعار النادي">
    <div class="welcome-title">نادي القيروان الموسمي</div>
    <div class="welcome-sub"><%= settings.season_name %> • يبدأ من 28 محرم</div>
    <div class="welcome-chips">
      <% clubDays.forEach(d => { %>
        <div class="welcome-chip">📅 <%= d %></div>
      <% }) %>
      <div class="welcome-chip">🏫 3 أسابيع</div>
    </div>
    <div class="welcome-programs">
      <div class="prog-badge"><span class="prog-badge-icon">🟦</span><span class="prog-badge-label">المعرفي</span></div>
      <div class="prog-badge"><span class="prog-badge-icon">⚽</span><span class="prog-badge-label">الرياضي</span></div>
      <div class="prog-badge"><span class="prog-badge-icon">🎭</span><span class="prog-badge-label">الترفيهي</span></div>
      <div class="prog-badge"><span class="prog-badge-icon">🌟</span><span class="prog-badge-label">التميز</span></div>
    </div>
  </div>

  <!-- ===== شريحة 2: المتصدرون ===== -->
  <div class="slide slide-leaders" id="slide-1">
    <div class="slide-title">🏆 المتصدرون</div>
    <div class="leaders-grid" id="leadersGrid">
      <div>
        <div class="leaders-col-title">🥇 الفئة العليا</div>
        <div id="leadersEulya"></div>
      </div>
      <div>
        <div class="leaders-col-title">🌠 الفئة الأولية</div>
        <div id="leadersAwlawiya"></div>
      </div>
    </div>
  </div>

  <!-- ===== شريحة 3: ترتيب المجموعات ===== -->
  <div class="slide slide-groups" id="slide-2">
    <div class="slide-title">📊 ترتيب المجموعات</div>
    <div class="groups-display-grid" id="groupsDisplayGrid"></div>
  </div>

  <!-- ===== شريحة 4: إحصائيات اليوم ===== -->
  <div class="slide slide-stats" id="slide-3">
    <div class="slide-title">📈 نظرة عامة على النادي</div>
    <div class="stats-display-grid">
      <div class="stat-display-card">
        <span class="sdc-icon">👥</span>
        <span class="sdc-value" id="statStudents"><%= stats.totalStudents %></span>
        <span class="sdc-label">عدد الطلاب</span>
      </div>
      <div class="stat-display-card">
        <span class="sdc-icon">✅</span>
        <span class="sdc-value" id="statAttendance"><%= stats.attendanceRate %></span>
        <span class="sdc-label">إجمالي الحضور</span>
      </div>
      <div class="stat-display-card">
        <span class="sdc-icon">🏅</span>
        <span class="sdc-value" id="statGroups"><%= stats.totalGroups %></span>
        <span class="sdc-label">عدد المجموعات</span>
      </div>
      <div class="stat-display-card">
        <span class="sdc-icon">🟦</span>
        <span class="sdc-value" id="statKnowledge"><%= stats.totalKnowledge %></span>
        <span class="sdc-label">نقاط المعرفي</span>
      </div>
      <div class="stat-display-card">
        <span class="sdc-icon">⚽</span>
        <span class="sdc-value" id="statSports"><%= stats.totalSports %></span>
        <span class="sdc-label">نقاط الرياضي</span>
      </div>
      <div class="stat-display-card">
        <span class="sdc-icon">🎭</span>
        <span class="sdc-value" id="statCultural"><%= stats.totalCultural %></span>
        <span class="sdc-label">نقاط الترفيهي</span>
      </div>
    </div>
    <div class="session-banner" id="sessionBanner">⏳ جارٍ تحميل الجلسة...</div>
  </div>

  <!-- ===== شريحة 5: البرامج ===== -->
  <div class="slide slide-programs" id="slide-4">
    <div class="slide-title">🎯 برامج النادي الأربعة</div>
    <div class="programs-display-grid">
      <div class="prog-display-card">
        <span class="pdc-icon">🟦</span>
        <div class="pdc-title">البرنامج المعرفي</div>
        <div class="pdc-desc">يشمل برامج هادفة تنمّي الفكر والمهارات، مثل الذكاء الاصطناعي، والآداب، وبرنامج "صلاتي سعادتي"، وأنشطة تعليمية وتفاعلية.</div>
      </div>
      <div class="prog-display-card">
        <span class="pdc-icon">⚽️</span>
        <div class="pdc-title">البرنامج الرياضي</div>
        <div class="pdc-desc">يعزز اللياقة البدنية وروح المنافسة عبر الألعاب والبطولات والأنشطة الرياضية في بيئة تشجع التعاون والمرح.</div>
      </div>
      <div class="prog-display-card">
        <span class="pdc-icon">🎭</span>
        <div class="pdc-title">البرنامج الترفيهي</div>
        <div class="pdc-desc">تجربة مليئة بالمتعة عبر الألعاب الجماعية والمسابقات والأنشطة الإبداعية التي تنمي الثقة بالنفس وروح الفريق.</div>
      </div>
      <div class="prog-display-card">
        <span class="pdc-icon">🌟</span>
        <div class="pdc-title">التميز والمبادرات</div>
        <div class="pdc-desc">يُكرّم الطلاب المتميزين وأصحاب المبادرات الإيجابية ويشجع على الإبداع والتعاون وتحمل المسؤولية.</div>
      </div>
    </div>
  </div>

</div><!-- end slides-wrapper -->

<script>
  const SLIDE_COUNT   = 5;
  const SLIDE_DURATION = 7000; // مللي ثانية
  const REFRESH_INTERVAL = 60000; // تحديث البيانات كل دقيقة

  let currentSlide = 0;
  let timer = null;
  let progressTimer = null;

  /* ======= الساعة الحية ======= */
  function updateClock() {
    const now = new Date();
    document.getElementById('liveClock').textContent =
      now.toLocaleTimeString('ar-SA', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  updateClock();
  setInterval(updateClock, 1000);

  /* ======= نقاط المؤشر ======= */
  const dotsEl = document.getElementById('slideDots');
  for (let i = 0; i < SLIDE_COUNT; i++) {
    const d = document.createElement('div');
    d.className = 'dot' + (i === 0 ? ' active' : '');
    d.addEventListener('click', () => goToSlide(i));
    dotsEl.appendChild(d);
  }

  /* ======= شريط التقدم ======= */
  function startProgress() {
    const fill = document.getElementById('progressFill');
    fill.style.transition = 'none';
    fill.style.width = '0%';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        fill.style.transition = `width ${SLIDE_DURATION}ms linear`;
        fill.style.width = '100%';
      });
    });
  }

  /* ======= التنقل بين الشرائح ======= */
  function goToSlide(n) {
    document.getElementById('slide-' + currentSlide).classList.remove('active');
    dotsEl.children[currentSlide].classList.remove('active');
    currentSlide = (n + SLIDE_COUNT) % SLIDE_COUNT;
    document.getElementById('slide-' + currentSlide).classList.add('active');
    dotsEl.children[currentSlide].classList.add('active');
    startProgress();
    clearTimeout(timer);
    timer = setTimeout(() => goToSlide(currentSlide + 1), SLIDE_DURATION);
  }

  /* ======= جلب البيانات وتحديث الشرائح ======= */
  async function refreshData() {
    try {
      const res  = await fetch('/api/display/data');
      const data = await res.json();

      /* المتصدرون */
      ['Eulya', 'Awlawiya'].forEach((key, idx) => {
        const category = idx === 0 ? 'الفئة العليا' : 'الأولوية';
        const list = (data.topByCategory[category] || []).slice(0, 5);
        document.getElementById('leaders' + key).innerHTML = list.map((s, i) => `
          <div class="leader-row ${i < 3 ? 'r' + (i+1) : ''}">
            <span class="leader-rank">${['🥇','🥈','🥉'][i] || (i+1)}</span>
            <div>
              <div class="leader-name">${s.name}</div>
              <div class="leader-group">${s.group_name}</div>
            </div>
            <span class="leader-pts">${s.total_points}</span>
          </div>`).join('');
      });

      /* المجموعات */
      const medals = ['🥇','🥈','🥉'];
      document.getElementById('groupsDisplayGrid').innerHTML =
        data.groups.map((g, i) => `
          <div class="group-display-card ${i < 3 ? 'g'+(i+1) : ''}">
            <span class="gd-rank">${medals[i] || i+1}</span>
            <div class="gd-info">
              <div class="gd-name">${g.name}</div>
              <div class="gd-cat">${g.category === 'الأولوية' ? 'الفئة الأولية' : 'الفئة العليا'} • ${g.member_count} طالب</div>
            </div>
            <span class="gd-pts">${g.total_points}</span>
          </div>`).join('');

      /* الإحصائيات */
      document.getElementById('statStudents').textContent   = data.stats.totalStudents;
      document.getElementById('statAttendance').textContent = data.stats.attendanceRate;
      document.getElementById('statGroups').textContent     = data.stats.totalGroups;
      document.getElementById('statKnowledge').textContent  = data.stats.totalKnowledge;
      document.getElementById('statSports').textContent     = data.stats.totalSports;
      document.getElementById('statCultural').textContent   = data.stats.totalCultural;

      /* الجلسة الحالية */
      if (data.currentSession) {
        const s = data.currentSession;
        document.getElementById('sessionBanner').textContent =
          `📅 الجلسة الحالية: الأسبوع ${s.week_number} — ${s.day_name} (${s.session_date})`;
      } else {
        document.getElementById('sessionBanner').textContent = '📅 لا توجد جلسة نشطة حالياً';
      }
    } catch (e) {
      console.error('خطأ في تحديث البيانات:', e);
    }
  }

  /* ======= Fullscreen ======= */
  document.getElementById('fsBtn').addEventListener('click', () => {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch(() => {});
      document.getElementById('fsBtn').textContent = '✕';
    } else {
      document.exitFullscreen();
      document.getElementById('fsBtn').textContent = '⛶';
    }
  });

  /* ======= تشغيل ======= */
  refreshData();
  setInterval(refreshData, REFRESH_INTERVAL);
  timer = setTimeout(() => goToSlide(1), SLIDE_DURATION);
  startProgress();
</script>
</body>
</html>
