<%- include('partials/header') %>

  <section class="app-section active">
    <h2 class="section-title">المجموعات</h2>
    <p class="section-desc">المجموعات مقسَّمة إلى فئتين، وكل مجموعة مرتبة حسب إجمالي نقاطها داخل فئتها</p>

    <div class="category-block">
      <h3 class="category-title minor">
        <span class="category-dot"></span>
        الفئة الصغرى
      </h3>
      <% if (minorGroups.length === 0) { %>
        <p class="empty-note">لا توجد مجموعات في هذه الفئة حالياً</p>
      <% } else { %>
        <div class="groups-container">
          <% minorGroups.forEach((group, index) => { %>
            <%- include('partials/group-card', { group, index }) %>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="category-block">
      <h3 class="category-title major">
        <span class="category-dot"></span>
        الفئة العليا
      </h3>
      <% if (majorGroups.length === 0) { %>
        <p class="empty-note">لا توجد مجموعات في هذه الفئة حالياً</p>
      <% } else { %>
        <div class="groups-container">
          <% majorGroups.forEach((group, index) => { %>
            <%- include('partials/group-card', { group, index }) %>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

<%- include('partials/footer') %>
